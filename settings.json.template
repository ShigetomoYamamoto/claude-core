{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(claude *)",
      "Bash(curl *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/protected-branch-edit-guard.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/opus-execution-guard.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/doc-blocker.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/git-destructive-blocker.py"
          },
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/pr-base-checker.py"
          },
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/mass-delete-blocker.py"
          },
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/git-add-secret-blocker.py"
          },
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/commit-msg-convention.py"
          },
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/opus-execution-guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/hooks/secret-detection.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay > /dev/null 2>&1 && afplay -v 0.2 /System/Library/Sounds/Glass.aiff || printf '\\a'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay > /dev/null 2>&1 && afplay -v 0.2 /System/Library/Sounds/Ping.aiff || printf '\\a'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    }
  },
  "effortLevel": "high",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
